{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": ["IQ200"],
  "contact": {},
  "icon": "assets/heigui/icon.png",
  "license": "All Rights Reserved",
  "environment": "client",
  "entrypoints": {
    "modmenu": [
      "com.iq200.heigui.clickgui.ModMenuIntegration"
    ],
    "client": [
      {
        "adapter": "kotlin",
        "value": "com.iq200.heigui.Heigui"
      }
    ]
  },
  "mixins": [
    "heigui.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": ">=${fabric_api_version}",
    "minecraft": "~${minecraft_version}",
    "fabric-language-kotlin": ">=${fabric_kotlin_version}"
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.discord": "https://discord.gg/eBUXV4ZCZs"
      },
      "update_checker": true
    }
  },
  "accessWidener": "heigui.accesswidener"
}